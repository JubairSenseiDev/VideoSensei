{
  "name": "videosensei",
  "version": "1.1.0",
  "description": "Master your video. Sensei-grade clarity. — Modern cross-platform video compressor.",
  "type": "module",
  "main": "dist/videosensei.js",
  "bin": {
    "videosensei": "dist/videosensei.js"
  },
  "scripts": {
    "build": "esbuild src/main.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/videosensei.js --banner:js='#!/usr/bin/env node' --keep-names",
    "build:cjs": "esbuild src/main.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/videosensei.js --banner:js='#!/usr/bin/env node' --keep-names",
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "node dist/videosensei.js --help",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "video",
    "compress",
    "ffmpeg",
    "h264",
    "h265",
    "av1",
    "sensei",
    "jubair"
  ],
  "author": "Jubair Sensei <jubairsensei@gmail.com> (https://jubairsensei.com)",
  "license": "MIT",
  "homepage": "https://github.com/JubairSenseiDev/VideoSensei",
  "repository": {
    "type": "git",
    "url": "https://github.com/JubairSenseiDev/VideoSensei.git"
  },
  "bugs": {
    "url": "https://github.com/JubairSenseiDev/VideoSensei/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
